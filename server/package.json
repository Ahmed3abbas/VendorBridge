{
  "name": "vendorbridge-server",
  "version": "1.0.0",
  "description": "VendorBridge backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
